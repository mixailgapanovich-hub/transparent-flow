# Скопируйте этот файл в .env и подставьте свои значения

# Параметры подключения к PostgreSQL.
# По умолчанию совпадают с docker-compose.yml в корне репозитория.
DATABASE_URL=postgres://tflow:tflow@localhost:5432/transparent_flow

# Порт, на котором поднимается Express-сервер
PORT=3001

# Origin фронтенда для CORS (Vite по умолчанию)
CORS_ORIGIN=http://localhost:5173

# Секрет для подписи JWT. В проде обязательно положить длинный случайный.
JWT_SECRET=dev-secret-change-me-please
# Время жизни JWT (формат библиотеки jsonwebtoken)
JWT_TTL=24h

# Каскад уведомлений (FR-04). По умолчанию — раз в час, в 00 минут.
NOTIFICATION_CRON=0 * * * *

# Telegram-бот: создать у @BotFather, подставить токен + username (без @).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=dev-webhook-secret
# Публичный URL (ngrok/cloudflare tunnel) для регистрации webhook у Telegram:
# TELEGRAM_WEBHOOK_URL=https://abcd.ngrok-free.app

# SMTP. Если все поля пустые — используется Ethereal тестовый SMTP,
# preview-URL писем выводится в лог.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=АденаДиджитал
