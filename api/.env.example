# Скопируйте этот файл в .env и подставьте свои значения

# Параметры подключения к PostgreSQL.
# По умолчанию совпадают с docker-compose.yml в корне репозитория.
DATABASE_URL=postgres://tflow:tflow@localhost:5432/transparent_flow

# Порт, на котором поднимается Express-сервер
PORT=3001

# Origin фронтенда для CORS (Vite по умолчанию)
CORS_ORIGIN=http://localhost:5173
